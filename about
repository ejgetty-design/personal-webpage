<script>
// ── STORY PLAYER — Paced single-card reveal ──
const storyArc = [
  { chapter: "Chapter 1 · CPA + MBA", lines: [
    { text: '"She has the credentials — but did she earn them the hard way?"', type: 'question' },
    { text: 'I passed all four CPA exams while working full time.', type: 'body' },
    { text: 'Then earned my MBA from CU Leeds while running finance for a $15M company.', type: 'body' },
    { text: "I didn't take a break to go back to school. I did both at once.", type: 'body' },
    { text: "Because that's how I'm wired.", type: 'punchline' }
  ]},
  { chapter: "Chapter 2 · Blue Moose Costco Deal", lines: [
    { text: '"We just landed a $6M Costco deal. Can we actually execute on this?"', type: 'question' },
    { text: "The real question wasn't whether to take it — it was whether we could survive it.", type: 'body' },
    { text: 'I built the financial model that answered that.', type: 'body' },
    { text: 'Demand planning, inventory, spoilage, cash flow — the whole picture.', type: 'body' },
    { text: 'The company grew from <strong>$8M to $15M</strong> that year.', type: 'body' },
    { text: "I wasn't in sales. I was the reason sales was possible.", type: 'punchline' }
  ]},
  { chapter: "Chapter 3 · AVL — Breadth Across Industries", lines: [
    { text: '"How do you build finance for any company?"', type: 'question' },
    { text: 'At AVL, I served <strong>15 clients</strong> across 2 years, owning anywhere from 5–8 books at a time.', type: 'body' },
    { text: 'CPG, SaaS, manufacturing, cannabis startups — all different stages, all different problems to solve.', type: 'body' },
    { text: 'I led cash-to-accrual conversions, system implementations, and establishing the structure of the control environment.', type: 'body' },
    { text: "One client's monthly close went from <strong>4 weeks to 1</strong>.", type: 'body' },
    { text: "The skill isn't industry knowledge. It's reading a company fast and building what it needs.", type: 'punchline' }
  ]},
  { chapter: "Chapter 4 · OneTogether — Scale", lines: [
    { text: '"We need to manage five companies now. Can you build the infrastructure?"', type: 'question' },
    { text: 'When I joined OneTogether, there was one entity. Now there are five.', type: 'body' },
    { text: 'I built the financial infrastructure that supported that growth.', type: 'body' },
    { text: 'Chart of accounts, consolidated reporting, audit-ready close, board-level snapshots.', type: 'body' },
    { text: 'There was no playbook.', type: 'body' },
    { text: 'I wrote it.', type: 'punchline' }
  ]}
];

let currentChapter = 0;
let currentLine = 0;
let storyAnimating = false;

const storyTextEl = document.getElementById('storyText');
const chapterLabelEl = document.getElementById('chapterLabel');
const counterEl = document.getElementById('storyCounter');
const backBtn = document.getElementById('storyBack');
const nextBtn = document.getElementById('storyNext');

function renderStory() {
  const chapter = storyArc[currentChapter];
  const line = chapter.lines[currentLine];
  const totalLines = chapter.lines.length;

  // Update chapter label
  chapterLabelEl.textContent = chapter.chapter;

  // Update progress pips
  for (let i = 0; i < storyArc.length; i++) {
    const fill = document.getElementById('chFill' + i);
    if (i < currentChapter) fill.style.width = '100%';
    else if (i === currentChapter) {
      const pct = ((currentLine + 1) / totalLines) * 100;
      fill.style.width = pct + '%';
    } else fill.style.width = '0%';
  }

  // Update text with type styling
  storyTextEl.classList.remove('is-question', 'is-punchline');
  if (line.type === 'question') storyTextEl.classList.add('is-question');
  else if (line.type === 'punchline') storyTextEl.classList.add('is-punchline');
  storyTextEl.innerHTML = line.text;

  // Update counter
  counterEl.textContent = (currentLine + 1) + ' of ' + totalLines;

  // Disable back at very start
  backBtn.disabled = (currentChapter === 0 && currentLine === 0);

  // Next button text changes on last line of last chapter
  if (currentChapter === storyArc.length - 1 && currentLine === totalLines - 1) {
    nextBtn.textContent = '↻ Restart';
  } else {
    nextBtn.textContent = 'Next →';
  }
}

function storyAdvance() {
  if (storyAnimating) return;
  const totalLines = storyArc[currentChapter].lines.length;

  // If at end of everything, restart
  if (currentChapter === storyArc.length - 1 && currentLine === totalLines - 1) {
    fadeAndUpdate(() => {
      currentChapter = 0;
      currentLine = 0;
    });
    return;
  }

  fadeAndUpdate(() => {
    if (currentLine < totalLines - 1) {
      currentLine++;
    } else {
      currentChapter++;
      currentLine = 0;
    }
  });
}

function storyBack() {
  if (storyAnimating) return;
  if (currentChapter === 0 && currentLine === 0) return;

  fadeAndUpdate(() => {
    if (currentLine > 0) {
      currentLine--;
    } else {
      currentChapter--;
      currentLine = storyArc[currentChapter].lines.length - 1;
    }
  });
}

function goToChapter(chapterIndex) {
  if (storyAnimating || chapterIndex === currentChapter) return;
  fadeAndUpdate(() => {
    currentChapter = chapterIndex;
    currentLine = 0;
  });
}

function fadeAndUpdate(updateFn) {
  storyAnimating = true;
  storyTextEl.classList.add('fade-out');
  setTimeout(() => {
    updateFn();
    renderStory();
    storyTextEl.classList.remove('fade-out');
    storyTextEl.classList.add('fade-in');
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        storyTextEl.classList.remove('fade-in');
      });
    });
    setTimeout(() => { storyAnimating = false; }, 450);
  }, 350);
}

// Initial render
renderStory();
</script>
</body>
</html>
