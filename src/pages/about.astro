---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';
import Eyebrow from '@/components/Eyebrow.astro';
import Button from '@/components/Button.astro';

const CALENDLY = 'https://calendly.com/ejgetty/30min';

const principles = [
  {
    title: "Two clients at a time. That's it.",
    tagline: 'Depth, not volume.',
    body: 'Most fractional controllers juggle eight to ten clients at once. Ridgeline takes a maximum of two — which means your business gets real attention, fast response times, and a partner who actually knows your books.',
  },
  {
    title: "We run the stack, so you don't have to.",
    tagline: 'Finance systems end-to-end: evaluate, implement, optimize, maintain.',
    body: "You shouldn't need to become a QuickBooks admin or a NetSuite expert to run your business. The systems layer is ours to own — from selection through implementation through the monthly workflows that keep everything running quietly in the background.",
  },
  {
    title: 'Flat fees. No scope creep. No surprise invoices.',
    tagline: 'You know what finance costs before we start.',
    body: 'Traditional fractional engagements run on hourly billing, which means every conversation, every extra transaction, every month-end scramble becomes a line item. Ridgeline prices by outcome, not by hour — so the cost is predictable and the incentives are aligned with getting the work right.',
  },
  {
    title: 'Licensed CPA. Senior-led. Audit-ready by default.',
    tagline: 'The person selling the engagement is the person doing the work.',
    body: "Most fractional services aren't staffed by licensed CPAs, and most regional firms hand off your books to junior staff once the contract is signed. At Ridgeline, you work directly with a CPA and MBA who has built and run finance functions from the inside — no handoffs, no rotating team, no learning on your books.",
  },
];

const credentials = [
  'MBA · CPA',
  '13+ years CPA experience',
  '12+ external audits led',
  'NetSuite · QuickBooks · Ramp',
];
---

<BaseLayout
  title="About — Ridgeline Finance"
  description="Ridgeline Finance was founded to bring controller-level discipline to the growing businesses that need it most."
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-paper text-ink py-20 md:py-32">
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 opacity-[0.06]"
      style="background-image: url('/ridge-motif.svg'); background-size: cover; background-position: center bottom; background-repeat: no-repeat;"
    ></div>
    <div class="relative mx-auto max-w-[1200px] px-6 md:px-10">
      <Eyebrow>About</Eyebrow>
      <h1
        class="font-display mt-5 max-w-[20ch]"
        style="font-size: var(--text-display);"
      >
        Finance built by a controller, for founders.
      </h1>
      <p class="mt-6 max-w-[62ch] text-[length:var(--text-lead)] text-ink-muted">
        13 years turning financial complexity into clarity — building the systems, leading the teams, and telling the story behind the numbers for high-growth companies.
      </p>
    </div>
  </section>

  <!-- Our story -->
  <Section bg="paper" size="md" id="story">
    <div class="grid gap-12 md:grid-cols-12">
      <div class="md:col-span-4">
        <Eyebrow>Our story</Eyebrow>
        <h2 class="font-display mt-4" style="font-size: var(--text-h1);">
          Why we exist.
        </h2>
      </div>
      <div class="md:col-span-8 space-y-5 text-[length:var(--text-lead)] max-w-[60ch]">
        <p>
          Every growing business eventually hits the same wall. The bookkeeper who got them this far can't keep up. A full-time controller costs more than they can justify. And the financial data — the thing leadership most needs to make decisions — becomes the least reliable part of the business.
        </p>
        <p>
          We built Ridgeline to fix that gap. We bring the structure, systems thinking, and close discipline of an in-house controller, delivered as a service. Our clients get books they can trust, operations that run without friction, and financials their leadership can actually use to make decisions.
        </p>
      </div>
    </div>
  </Section>

  <!-- Meet Emma -->
  <Section bg="cream" size="md" id="founder">
    <Eyebrow>Meet the founder</Eyebrow>
    <div class="mt-8 grid gap-10 md:grid-cols-12 md:items-start">
      <div class="md:col-span-4">
        <figure class="overflow-hidden rounded-lg border border-rule bg-paper">
          <img
            src="/emma-headshot.jpeg"
            alt="Emma Getty, Founder & Controller at Ridgeline Finance"
            width="640"
            height="800"
            loading="lazy"
            class="block w-full h-auto"
          />
        </figure>
      </div>
      <div class="md:col-span-8">
        <h2 class="font-display leading-tight" style="font-size: var(--text-h1);">
          Emma Getty, MBA, CPA
        </h2>
        <p class="mt-2 font-display text-[1.125rem] text-ink-muted italic">
          Founder & Controller
        </p>
        <a
          href="https://www.linkedin.com/in/emma-getty-cpa-mba"
          target="_blank"
          rel="noopener"
          class="mt-3 inline-flex items-center gap-2 text-[0.9375rem] text-ink-muted hover:text-forest transition-colors"
          aria-label="Emma Getty on LinkedIn"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.852 3.37-1.852 3.601 0 4.266 2.37 4.266 5.455v6.288zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          <span>LinkedIn</span>
        </a>
        <div class="mt-6 space-y-5 text-[length:var(--text-body)] max-w-[60ch]">
          <p>
            Emma is a CPA with 13+ years of experience across high-growth companies. She has managed accounting across multiple entities, led more than a dozen external audits, and built the systems that let founders trust their numbers.
          </p>
          <p>
            Before founding Ridgeline, Emma led the finance function at OneTogether Solutions, a mission-driven, multi-entity healthcare management firm. She has worked in Boulder for 9 years in consulting, CPG, and startups. She led Blue Moose through a period of 63% revenue growth, where she also redesigned the monthly close process to save 40 hours a month.
          </p>
          <p>
            She brings deep fluency in NetSuite, QuickBooks, and Ramp, and pairs controller-level technical depth with a founder-focused approach.
          </p>
        </div>
      </div>
    </div>
  </Section>

  <!-- What makes us different -->
  <Section bg="paper" size="md" id="approach">
    <Eyebrow>Our approach</Eyebrow>
    <h2 class="font-display mt-4 max-w-[22ch]" style="font-size: var(--text-h1);">
      What makes us different.
    </h2>
    <div class="mt-12 grid gap-10 md:grid-cols-2">
      {principles.map((p) => (
        <div class="border-t border-forest/20 pt-6">
          <h3 class="font-display text-[1.375rem] leading-tight">{p.title}</h3>
          <p class="mt-3 font-display text-[1.0625rem] text-ink-muted italic max-w-[48ch]">
            {p.tagline}
          </p>
          <p class="mt-4 text-[1rem] text-ink-muted leading-relaxed max-w-[48ch]">
            {p.body}
          </p>
        </div>
      ))}
    </div>
  </Section>

  <!-- Credentials strip -->
  <section class="border-y border-rule bg-paper">
    <div class="mx-auto max-w-[1200px] px-6 md:px-10 py-6">
      <ul class="flex flex-wrap items-center justify-center text-center text-[length:var(--text-small)] text-ink-muted">
        {credentials.map((item, i) => (
          <li class="flex items-center">
            <span class="px-4 md:px-5">{item}</span>
            {i < credentials.length - 1 && (
              <span aria-hidden="true" class="hidden md:inline text-ink-muted/40">•</span>
            )}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CTA -->
  <Section bg="cream" size="md" id="cta">
    <div class="mx-auto max-w-[640px] text-center">
      <h2 class="font-display" style="font-size: var(--text-h1);">
        Ready to bring Ridgeline into your business?
      </h2>
      <div class="mt-8 flex justify-center">
        <Button href={CALENDLY} variant="primary" size="lg" external>
          Book a consultation
        </Button>
      </div>
    </div>
  </Section>
</BaseLayout>
