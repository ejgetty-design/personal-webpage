---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';
import Eyebrow from '@/components/Eyebrow.astro';
import Button from '@/components/Button.astro';
import Card from '@/components/Card.astro';

const CALENDLY = 'https://calendly.com/ejgetty/30min';

const credibilityItems = [
  '13+ years CPA experience',
  '12+ external audits led',
  'Multi-entity accounting',
  'CPG · SaaS · Manufacturing · Healthcare',
];

const services = [
  {
    numbered: '01',
    title: 'Accounting & Close',
    description:
      'Clean monthly financials, delivered on a predictable rhythm. A close you can plan around.',
  },
  {
    numbered: '02',
    title: 'Finance Operations',
    description:
      'AP/AR, workflows, and cash visibility that run without pulling your team in every week.',
  },
  {
    numbered: '03',
    title: 'Systems & Automation',
    description:
      'Finance infrastructure built to scale — from first hire through multi-entity complexity.',
  },
  {
    numbered: '04',
    title: 'FP&A & Reporting',
    description:
      'Budgets, forecasts, and board-ready reporting built for founder decisions.',
  },
];

const whoWeServe = [
  {
    title: '$0–$50M in revenue',
    description:
      'You need finance that matches your growth trajectory — built for the stage you are in and the one ahead.',
  },
  {
    title: 'Multi-entity or growing complexity',
    description:
      'Consolidations, intercompany transactions, and layered structures handled accurately.',
  },
  {
    title: 'Founders who want to understand their numbers',
    description:
      'Numbers you actually trust, delivered in a way you can use.',
  },
];

const process = [
  {
    numbered: '01',
    title: 'Assess',
    description:
      'We start with a diagnostic of your current books, systems, and team. You get an honest read on where the gaps are and what it will take to close them.',
  },
  {
    numbered: '02',
    title: 'Implement',
    description:
      'We close the gaps — correct historicals, build an accurate monthly close, set up the tooling, and install the processes.',
  },
  {
    numbered: '03',
    title: 'Run',
    description:
      'Predictable monthly close, accurate financials, and operating insights your leadership team can act on. Quarterly planning and board presentation on request.',
  },
];

const faqs = [
  {
    q: 'How do you charge?',
    a: "We scope each engagement based on your company's stage, complexity, and the work involved. Most engagements are priced on a fixed monthly retainer; project-based work is quoted upfront.",
  },
  {
    q: 'How long is a typical engagement?',
    a: "Most engagements run 3 to 6 months to get systems and close discipline in place, with many clients continuing on an ongoing basis after that. We also take on defined projects — a systems implementation, an audit cleanup, a period-end rescue — when that's what the business needs.",
  },
  {
    q: 'Do you replace our existing bookkeeper?',
    a: "No. We are not here to bookkeep. We are here to integrate systems and implement structure so that you don't have to wait until month-end to understand how your business is performing.",
  },
  {
    q: 'What tools do you work with?',
    a: 'AP, AR, Payroll, Accounting, and Reporting systems will all be integrated to create a reliable, real-time understanding of the business.',
  },
  {
    q: 'What size of business do you work with?',
    a: 'Our sweet spot is $0–$50M in revenue. We scale the engagement to match your stage — from first finance hire through multi-entity complexity.',
  },
];

const SHOW_TESTIMONIALS = false;
---

<BaseLayout
  title="Ridgeline Finance — Fractional finance for growing companies"
  description="Controller-level finance for founders at $0–$50M. Accurate books, operational rigor, and systems that scale."
>
  <!-- 1. Hero -->
  <section class="relative overflow-hidden bg-paper text-ink py-20 md:py-32">
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 opacity-[0.06]"
      style="background-image: url('/ridge-motif.svg'); background-size: cover; background-position: center bottom; background-repeat: no-repeat;"
    ></div>
    <div class="relative mx-auto max-w-[1200px] px-6 md:px-10">
      <Eyebrow>Fractional finance for growing companies</Eyebrow>
      <h1
        class="font-display mt-5 max-w-[20ch]"
        style="font-size: var(--text-display);"
      >
        Finance that brings <em>clarity and structure</em> to your growth.
      </h1>
      <p class="mt-6 max-w-[56ch] text-[length:var(--text-lead)] text-ink-muted">
        We are here to support your next stage of growth with accurate and real-time financials.
      </p>
      <div class="mt-10 flex flex-wrap items-center gap-4">
        <Button href={CALENDLY} variant="primary" size="lg" external>
          Book a consultation
        </Button>
        <Button href="#how-we-work" variant="secondary" size="lg">
          See how we work
        </Button>
      </div>
    </div>
  </section>

  <!-- 2. Credibility strip -->
  <section class="border-y border-rule bg-paper">
    <div class="mx-auto max-w-[1200px] px-6 md:px-10 py-6">
      <ul class="flex flex-wrap items-center justify-center text-center text-[length:var(--text-small)] text-ink-muted">
        {credibilityItems.map((item, i) => (
          <li class="flex items-center">
            <span class="px-5 md:px-7">{item}</span>
            {i < credibilityItems.length - 1 && (
              <span aria-hidden="true" class="hidden md:inline text-ink-muted/40">•</span>
            )}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- 3. What we do -->
  <Section bg="paper" size="md" id="services">
    <Eyebrow>What we do</Eyebrow>
    <div class="mt-4 flex flex-wrap items-end justify-between gap-6">
      <h2 class="font-display max-w-[18ch]" style="font-size: var(--text-h1);">
        Four services, one disciplined approach.
      </h2>
    </div>
    <div class="mt-10 grid gap-6 md:grid-cols-2">
      {services.map((s) => (
        <Card numbered={`${s.numbered} ·`} title={s.title} description={s.description} />
      ))}
    </div>
    <div class="mt-10">
      <Button href="/services" variant="ghost">
        Explore services in detail →
      </Button>
    </div>
  </Section>

  <!-- 4. Who we serve -->
  <Section bg="cream" size="md" id="who">
    <Eyebrow>Who we serve</Eyebrow>
    <h2 class="font-display mt-4 max-w-[22ch]" style="font-size: var(--text-h1);">
      Built for founders past early stage.
    </h2>
    <div class="mt-12 grid gap-10 md:grid-cols-3">
      {whoWeServe.map((w) => (
        <div class="border-t border-forest/20 pt-6">
          <h3 class="font-display text-[1.375rem] leading-tight">{w.title}</h3>
          <p class="mt-3 text-[1rem] text-ink-muted leading-relaxed">{w.description}</p>
        </div>
      ))}
    </div>
    <div class="mt-10">
      <Button href="/about" variant="ghost">
        Meet the founder →
      </Button>
    </div>
  </Section>

  <!-- 5. How we work -->
  <Section bg="paper" size="md" id="how-we-work">
    <Eyebrow>How we work</Eyebrow>
    <h2 class="font-display mt-4 max-w-[22ch]" style="font-size: var(--text-h1);">
      A disciplined monthly rhythm.
    </h2>
    <p class="mt-6 max-w-[60ch] text-[length:var(--text-lead)] text-ink-muted">
      Every Ridgeline engagement follows the same three-phase approach.
    </p>
    <ol class="mt-12 grid gap-10 md:grid-cols-3">
      {process.map((p) => (
        <li class="relative border-t border-forest/20 pt-6">
          <div class="font-display text-[0.9375rem] text-sage tracking-wider mb-4">
            {p.numbered}
          </div>
          <h3 class="font-display text-[1.5rem] leading-tight">{p.title}</h3>
          <p class="mt-3 text-[1rem] text-ink-muted leading-relaxed">{p.description}</p>
        </li>
      ))}
    </ol>
  </Section>

  {SHOW_TESTIMONIALS && (
    <Section bg="paper" size="md" id="testimonials">
      <Eyebrow>What founders say</Eyebrow>
      <h2 class="font-display mt-4" style="font-size: var(--text-h1);">
        Words from the teams we work with.
      </h2>
      <!-- Testimonial cards will be rendered here when quotes are available. -->
    </Section>
  )}

  <!-- 7. FAQ -->
  <Section bg="paper" size="md" id="faq">
    <Eyebrow>FAQ</Eyebrow>
    <h2 class="font-display mt-4 max-w-[22ch]" style="font-size: var(--text-h1);">
      Questions founders ask us.
    </h2>
    <div class="mt-10 max-w-[780px] divide-y divide-rule border-y border-rule">
      {faqs.map((f) => (
        <details class="group py-5">
          <summary class="flex cursor-pointer list-none items-start justify-between gap-6 font-display text-[1.25rem] leading-snug">
            <span>{f.q}</span>
            <span
              aria-hidden="true"
              class="mt-1 shrink-0 text-ink-muted transition-transform group-open:rotate-45"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round">
                <path d="M12 5v14M5 12h14" />
              </svg>
            </span>
          </summary>
          <p class="mt-4 max-w-[64ch] text-[1rem] text-ink-muted leading-relaxed">
            {f.a}
          </p>
        </details>
      ))}
    </div>
  </Section>

  <!-- 8. CTA band -->
  <Section bg="cream" size="md" id="cta">
    <div class="mx-auto max-w-[640px] text-center">
      <h2 class="font-display" style="font-size: var(--text-h1);">
        Ready to bring clarity to your finances?
      </h2>
      <p class="mt-5 text-[length:var(--text-lead)] text-ink-muted">
        A free 30-minute consultation. We'll talk through where your business is today and what a stronger financial foundation could look like. No commitment required.
      </p>
      <div class="mt-8 flex justify-center">
        <Button href={CALENDLY} variant="primary" size="lg" external>
          Book a call
        </Button>
      </div>
    </div>
  </Section>
</BaseLayout>
