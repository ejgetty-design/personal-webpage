---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'md' | 'lg';
  external?: boolean;
  class?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  external = false,
  class: className = '',
} = Astro.props;

const base =
  'inline-flex items-center justify-center gap-2 rounded-md font-medium transition-colors select-none';

const sizes = {
  md: 'px-4 py-2 text-[0.9375rem]',
  lg: 'px-5 py-3 text-[1rem]',
};

const variants = {
  primary: 'bg-forest text-paper hover:bg-forest-hover',
  secondary:
    'bg-transparent text-forest border border-forest hover:bg-forest hover:text-paper',
  ghost: 'bg-transparent text-forest hover:text-forest-hover underline-offset-4 hover:underline',
};

const rel = external ? 'noopener noreferrer' : undefined;
const target = external ? '_blank' : undefined;
---

<a
  href={href}
  class:list={[base, sizes[size], variants[variant], className]}
  target={target}
  rel={rel}
>
  <slot />
  {
    external && (
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M7 7h10v10" />
        <path d="M7 17 17 7" />
      </svg>
    )
  }
</a>
