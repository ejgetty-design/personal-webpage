---
interface Props {
  bg?: 'paper' | 'cream' | 'forest';
  size?: 'sm' | 'md' | 'lg';
  id?: string;
  class?: string;
}

const { bg = 'paper', size = 'md', id, class: className = '' } = Astro.props;

const bgs = {
  paper: 'bg-paper text-ink',
  cream: 'bg-cream text-ink',
  forest: 'bg-forest text-paper',
};

const paddings = {
  sm: 'py-12 md:py-16',
  md: 'py-14 md:py-20',
  lg: 'py-20 md:py-28',
};
---

<section id={id} class:list={[bgs[bg], paddings[size], className]}>
  <div class="mx-auto max-w-[1200px] px-6 md:px-10">
    <slot />
  </div>
</section>
